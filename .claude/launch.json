{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "chitty-workspace",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run"],
      "port": 8770
    },
    {
      "name": "chitty-ai",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "--manifest-path", "C:/Github/chitty-ai/server/Cargo.toml"],
      "port": 8080
    },
    {
      "name": "chitty-ai-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8090", "--directory", "C:/Github/chitty-ai"],
      "port": 8090
    }
  ]
}
