# Rust build artifacts
/target
**/*.rs.bk
*.pdb

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Environment
.env
.env.*

# Temporary
temp_scripts/

# Logs
*.log

# Certificates (generated at runtime)
*.cer
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo

# Installer build artifacts
installer/output/
installer/staging/
installer/*.zip
installer/get-pip.py

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# Binaries and installers that don't belong in source
*.exe
!target/

# SQL dumps
*.sql

# Local model files
*.gguf
*.pfx
