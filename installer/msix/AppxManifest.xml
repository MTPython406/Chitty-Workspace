<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10">

  <Identity
    Name="Chitty-Developer.ChittyWorkspace"
    Version="0.1.0.0"
    Publisher="CN=3BC7768D-D3BF-4879-81F1-488F375E8983"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Chitty Workspace</DisplayName>
    <PublisherDisplayName>Chitty-Developer</PublisherDisplayName>
    <Description>Your Machine | Your AI | Your Rules. Open-source, local-first AI assistant with agents, tools, browser automation, and marketplace. Build, deploy, and automate with any LLM provider or local models. Your data never leaves your computer.</Description>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.26200.0" />
  </Dependencies>

  <Capabilities>
    <!-- Full trust for Win32 desktop app (system tray, WebView2, child processes) -->
    <rescap:Capability Name="runFullTrust" />
    <!-- Internet access for LLM API calls (OpenAI, Anthropic, Google, xAI) -->
    <Capability Name="internetClient" />
    <!-- Local network for Ollama, HuggingFace sidecar, and local server (port 8770) -->
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>

  <Applications>
    <Application
      Id="ChittyWorkspace"
      Executable="ChittyWorkspace.exe"
      EntryPoint="Windows.FullTrustApplication"
      uap10:RuntimeBehavior="packagedClassicApp"
      uap10:TrustLevel="mediumIL">

      <uap:VisualElements
        DisplayName="Chitty Workspace"
        Description="Open-source AI assistant with agents, tools, browser automation, and marketplace. Supports any LLM provider or local GGUF models."
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png"
        BackgroundColor="transparent">

        <uap:DefaultTile
          Wide310x150Logo="Images\Wide310x150Logo.png"
          Square310x310Logo="Images\Square310x310Logo.png"
          ShortName="Chitty" />

      </uap:VisualElements>

      <!-- Register chitty:// protocol handler for marketplace installs -->
      <Extensions>
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="chitty">
            <uap:DisplayName>Chitty Protocol</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>
      </Extensions>

    </Application>
  </Applications>

</Package>
